{
  "name": "antigravity-jukebox",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,fe -c cyan,magenta \"npm run dev -w packages/api\" \"npm run dev -w packages/fe\"",
    "dev:api": "npm run dev -w packages/api",
    "dev:fe": "npm run dev -w packages/fe"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
