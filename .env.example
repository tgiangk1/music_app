# ==============================================================================
# Environment Variables — Antigravity Jukebox
# ==============================================================================
# Copy this file and create the appropriate .env for each environment.
# NEVER commit actual .env files with real secrets.
# ==============================================================================

# ---- Backend (packages/api/.env) ----

NODE_ENV=development          # development | staging | production
PORT=3001

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# JWT
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# CORS — URL of the frontend app
CLIENT_URL=http://localhost:5173

# Admin
FIRST_ADMIN_EMAIL=admin@example.com

# Spotify OAuth (optional — for Spotify integration)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/spotify/callback

# ---- Frontend (packages/fe/.env) ----

VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001


# ==============================================================================
# Per-Environment Values
# ==============================================================================
#
# DEVELOPMENT (local)
#   GOOGLE_CALLBACK_URL = http://localhost:3001/auth/google/callback
#   CLIENT_URL          = http://localhost:5173
#   VITE_API_URL        = http://localhost:3001
#   VITE_SOCKET_URL     = http://localhost:3001
#
# STAGING (develop branch)
#   GOOGLE_CALLBACK_URL = https://<render-staging>.onrender.com/auth/google/callback
#   CLIENT_URL          = https://<vercel-preview-url>.vercel.app
#   VITE_API_URL        = https://<render-staging>.onrender.com
#   VITE_SOCKET_URL     = https://<render-staging>.onrender.com
#
# PRODUCTION (main branch)
#   GOOGLE_CALLBACK_URL = https://<render-prod>.onrender.com/auth/google/callback
#   CLIENT_URL          = https://your-domain.com
#   VITE_API_URL        = https://<render-prod>.onrender.com
#   VITE_SOCKET_URL     = https://<render-prod>.onrender.com
